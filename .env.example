# Stripe — from the Stripe Dashboard (Developers > API keys). Use the test-mode
# keys while building (they start with sk_test_ / pk_test_), and switch to the
# live-mode keys only once you're ready to take real charges.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# Your deployed URL (Vercel sets this; use http://localhost:3000 locally)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
