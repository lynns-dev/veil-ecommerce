# Square — checkout's card form tokenizes the card client-side via the Web
# Payments SDK (lib/squareClient.js) and charges it server-side via
# /api/square-checkout (lib/squareServer.js). From a Square Developer app
# (developer.squareup.com > your app > Credentials/Locations).
SQUARE_ACCESS_TOKEN=
SQUARE_LOCATION_ID=
SQUARE_ENVIRONMENT=sandbox
# Same application/location/environment, exposed to the browser so the Web
# Payments SDK (card, Apple Pay, Google Pay, Cash App Pay) can mount client-
# side. NEXT_PUBLIC_SQUARE_ENVIRONMENT defaults to 'production' if unset —
# only set it to 'sandbox' explicitly while testing.
NEXT_PUBLIC_SQUARE_APPLICATION_ID=
NEXT_PUBLIC_SQUARE_LOCATION_ID=
NEXT_PUBLIC_SQUARE_ENVIRONMENT=sandbox

# QuickBooks Payments — not used on the live /checkout (Square is), but
# pages/checkout-qb.jsx is a standalone backup checkout page kept ready to
# switch to if Square ever needs to be swapped out. QB_CLIENT_ID/SECRET
# also back /api/admin/orders/refund for any legacy QuickBooks orders.
# One-time setup: visit /api/qb-auth/connect once (after setting these)
# to authorize; lib/qbServerAuth.js refreshes the token automatically
# after that. NEXT_PUBLIC_QB_ENVIRONMENT is the client-side counterpart —
# checkout-qb.jsx tokenizes cards directly against Intuit's sandbox or
# production API depending on this value; keep it matched to QB_ENVIRONMENT.
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENVIRONMENT=sandbox
NEXT_PUBLIC_QB_ENVIRONMENT=sandbox

# Stripe — no longer used at checkout. STRIPE_SECRET_KEY is kept only so
# the admin Orders tab can refund older orders placed via Stripe.
STRIPE_SECRET_KEY=

# Bankful — an alternate checkout integration exists in the codebase
# (lib/bankfulServer.js) but isn't currently wired up to /checkout; it hit a
# "merchant not configured" error from Bankful's gateway that needs to be
# resolved with Bankful support before it can be used again. Only needed if
# you have Bankful orders to refund via the admin Orders tab.
BANKFUL_USERNAME=
BANKFUL_PASSWORD=
BANKFUL_ENVIRONMENT=sandbox
BANKFUL_BASE_URL=

# KV store (Vercel KV or a standalone Upstash Redis both work — same REST API)
# used for admin sessions, reviews, discounts, analytics, and the
# QuickBooks refresh token.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Your deployed URL (Vercel sets this; use http://localhost:3000 locally)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app

# Password for /admin (revenue, funnel analytics, live visitors, review
# moderation). Sessions are stored in the same KV store above.
ADMIN_PASSWORD=

# Bearer token for /api/leads/export — lets a separate app (e.g. the email/
# subscriber tool) pull captured checkout leads (abandoned + purchased)
# without a browser login. Set this to any long random string and give the
# same value to whatever's calling that endpoint.
LEADS_API_KEY=
