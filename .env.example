# QuickBooks Payments — from an Intuit Developer app with Payments enabled
# (developer.intuit.com > your app > Keys & OAuth). QB_CLIENT_ID / QB_CLIENT_SECRET
# are the app's credentials, used to authorize once via /api/qb-auth/connect
# and to silently refresh the access token afterward — see DEPLOYMENT.md.
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENVIRONMENT=sandbox

# KV store (Vercel KV or a standalone Upstash Redis both work — same REST API)
# used to persist the QuickBooks refresh token between requests so checkout
# can renew its own access token automatically, all day, with no manual steps.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Your deployed URL (Vercel sets this; use http://localhost:3000 locally)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
