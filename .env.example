# Stripe — from the Stripe Dashboard > Developers > API keys. The key
# prefix (sk_test_/pk_test_ vs sk_live_/pk_live_) determines sandbox vs live
# mode directly.
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# From Developers > Webhooks > (your endpoint) > Signing secret, after
# registering https://YOUR_DOMAIN/api/stripe/webhook subscribed to the
# payment_intent.succeeded event. This is what actually fulfills orders —
# see pages/api/stripe/webhook.js.
STRIPE_WEBHOOK_SECRET=

# QuickBooks Payments — offered as a second option at checkout alongside
# Stripe. From an Intuit Developer app with Payments enabled
# (developer.intuit.com > your app > Keys & OAuth). QB_CLIENT_ID/
# QB_CLIENT_SECRET are the app's credentials, used to authorize once via
# /api/qb-auth/connect and to silently refresh the access token afterward —
# see DEPLOYMENT.md.
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENVIRONMENT=sandbox
# Same value as QB_ENVIRONMENT, exposed to the browser so client-side card
# tokenization (lib/qbPayments.js) hits the matching sandbox/production API.
NEXT_PUBLIC_QB_ENVIRONMENT=sandbox

# KV store (Vercel KV or a standalone Upstash Redis both work — same REST API)
# used for admin sessions, reviews, discounts, analytics, and the QuickBooks
# refresh token.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Your deployed URL (Vercel sets this; use http://localhost:3000 locally)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app

# Password for /admin (revenue, funnel analytics, live visitors, review
# moderation). Sessions are stored in the same KV store above.
ADMIN_PASSWORD=
