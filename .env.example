# QuickBooks Payments — checkout's card form tokenizes the card client-side
# (lib/qbPayments.js) and charges it server-side via /api/qb-checkout. From
# an Intuit Developer app with Payments enabled (developer.intuit.com >
# your app > Keys & OAuth). QB_CLIENT_ID/QB_CLIENT_SECRET are the app's
# credentials, used to authorize once via /api/qb-auth/connect and to
# silently refresh the access token afterward — see DEPLOYMENT.md.
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENVIRONMENT=sandbox
# Same value as QB_ENVIRONMENT, exposed to the browser so client-side card
# tokenization (lib/qbPayments.js) hits the matching sandbox/production API.
NEXT_PUBLIC_QB_ENVIRONMENT=sandbox

# Stripe — no longer used at checkout. STRIPE_SECRET_KEY is kept only so
# the admin Orders tab can refund older orders placed via Stripe.
STRIPE_SECRET_KEY=

# Bankful — an alternate checkout integration exists in the codebase
# (lib/bankfulServer.js) but isn't currently wired up to /checkout; it hit a
# "merchant not configured" error from Bankful's gateway that needs to be
# resolved with Bankful support before it can be used again. Only needed if
# you have Bankful orders to refund via the admin Orders tab.
BANKFUL_USERNAME=
BANKFUL_PASSWORD=
BANKFUL_ENVIRONMENT=sandbox
BANKFUL_BASE_URL=

# KV store (Vercel KV or a standalone Upstash Redis both work — same REST API)
# used for admin sessions, reviews, discounts, analytics, and the
# QuickBooks refresh token.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Your deployed URL (Vercel sets this; use http://localhost:3000 locally)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app

# Password for /admin (revenue, funnel analytics, live visitors, review
# moderation). Sessions are stored in the same KV store above.
ADMIN_PASSWORD=

# Bearer token for /api/leads/export — lets a separate app (e.g. the email/
# subscriber tool) pull captured checkout leads (abandoned + purchased)
# without a browser login. Set this to any long random string and give the
# same value to whatever's calling that endpoint.
LEADS_API_KEY=
