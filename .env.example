# QuickBooks Payments — from an Intuit Developer app with Payments enabled
# (developer.intuit.com > your app > Payments). QB_ACCESS_TOKEN comes from
# completing that app's OAuth flow and currently must be refreshed manually
# (~hourly) until a token-refresh job is added — see DEPLOYMENT.md.
QB_ACCESS_TOKEN=
QB_ENVIRONMENT=sandbox
# Your deployed URL (Vercel sets this; use http://localhost:3000 locally)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app
