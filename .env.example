# Bankful — checkout runs entirely through Bankful's Hosted Payment Page:
# the shopper is redirected off-site to enter their card, so raw card data
# never touches this app. BANKFUL_USERNAME/BANKFUL_PASSWORD are the
# merchant credentials Bankful issued you; BANKFUL_PASSWORD also doubles as
# the HMAC-SHA256 signing key for every request/callback (see
# lib/bankfulServer.js). BANKFUL_ENVIRONMENT picks the default base URL
# (sandbox vs live) — set BANKFUL_BASE_URL directly to override it if
# Bankful support gives you a different host for your account; the two
# base URLs Bankful documents (api-dev1.bankfulportal.com for sandbox vs
# api.paybybankful.com for live) weren't consistent across their own docs
# and examples as of this integration, so confirm which one your sandbox
# credentials actually work against before relying on the default.
BANKFUL_USERNAME=
BANKFUL_PASSWORD=
BANKFUL_ENVIRONMENT=sandbox
BANKFUL_BASE_URL=

# Stripe — no longer used at checkout. STRIPE_SECRET_KEY is kept only so
# the admin Orders tab can refund orders placed before the Bankful switch —
# see lib/stripeServer.js.
STRIPE_SECRET_KEY=

# QuickBooks Payments — no longer offered at checkout. QB_CLIENT_ID/
# QB_CLIENT_SECRET are kept only so the admin Orders tab can refund orders
# placed before the Bankful switch (they authorize the same refresh token
# originally set up via /api/qb-auth/connect — see DEPLOYMENT.md).
QB_CLIENT_ID=
QB_CLIENT_SECRET=
QB_ENVIRONMENT=sandbox

# KV store (Vercel KV or a standalone Upstash Redis both work — same REST API)
# used for admin sessions, reviews, discounts, analytics, pending Bankful
# orders awaiting webhook confirmation, and the QuickBooks refresh token.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Your deployed URL (Vercel sets this; use http://localhost:3000 locally)
NEXT_PUBLIC_BASE_URL=https://your-project.vercel.app

# Password for /admin (revenue, funnel analytics, live visitors, review
# moderation). Sessions are stored in the same KV store above.
ADMIN_PASSWORD=
